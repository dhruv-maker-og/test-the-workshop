# ============================================================
# Environment Variables for Copilot Review & Security Workshop
# ============================================================
# Copy this file to .env and fill in your values.
# NEVER commit the .env file to version control.
# ============================================================

# GitHub Personal Access Token (required for SDK automation)
# Create at: https://github.com/settings/tokens
# Required scopes: repo, read:org, copilot
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Node.js environment (development | production)
NODE_ENV=development

# Optional: Override the Copilot model used by SDK agents
# COPILOT_MODEL=gpt-4o

# Optional: Output directory for generated reports
# REPORT_OUTPUT_DIR=./samples/findings
